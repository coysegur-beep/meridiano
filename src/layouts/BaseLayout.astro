---
import '../styles/global.css';
import type { Lang } from '@i18n/ui';
import { useTranslations } from '@i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
}

const {
  title,
  description = 'Meridiano — Noticias globales, análisis económico en tiempo real y columnas de opinión.',
  lang,
  ogImage = '/og-default.jpg',
  canonical,
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
} = Astro.props;

const SITE = Astro.site?.toString().replace(/\/$/, '') || '';
const currentUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle = title.includes('Meridiano') ? title : `${title} · Meridiano`;

const t = useTranslations(lang);

// Schema.org NewsMediaOrganization + NewsArticle
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsMediaOrganization',
  '@id': `${SITE}/#organization`,
  name: 'Meridiano',
  url: SITE,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE}/logo.png`,
    width: 512,
    height: 512,
  },
  sameAs: [
    'https://twitter.com/meridiano',
    'https://facebook.com/meridiano',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE}/#website`,
  url: SITE,
  name: 'Meridiano',
  description,
  publisher: { '@id': `${SITE}/#organization` },
  inLanguage: lang === 'es' ? 'es-CO' : 'en-US',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: `${SITE}/buscar?q={search_term_string}` },
    'query-input': 'required name=search_term_string',
  },
};

const articleSchema = type === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description,
  image: ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`,
  datePublished: publishedTime,
  dateModified: modifiedTime || publishedTime,
  author: { '@type': 'Person', name: author || 'Meridiano' },
  publisher: {
    '@type': 'Organization',
    name: 'Meridiano',
    logo: { '@type': 'ImageObject', url: `${SITE}/logo.png` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': currentUrl },
  inLanguage: lang,
  isAccessibleForFree: true,
  isPartOf: { '@id': `${SITE}/#website` },
} : null;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={currentUrl} />
  <link rel="alternate" hreflang="es" href={`${SITE}${Astro.url.pathname.replace(/^\/en/, '')}`} />
  <link rel="alternate" hreflang="en" href={`${SITE}/en${Astro.url.pathname.replace(/^\/en/, '')}`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE}${Astro.url.pathname.replace(/^\/en/, '')}`} />

  <!-- OG / Twitter -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`} />
  <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
  <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />
  <meta property="og:site_name" content="Meridiano" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  {author && <meta property="article:author" content={author} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@meridiano" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`} />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Meridiano" href="/rss.xml" />
  <link rel="alternate" type="application/rss+xml" title="Meridiano (EN)" href="/en/rss.xml" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style"
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,700;9..144,900&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=Instrument+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
  <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,700;9..144,900&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=Instrument+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0A0A0A" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black" />
  <slot name="head" />
</head>
<body class="relative">
  <slot />
</body>
</html>

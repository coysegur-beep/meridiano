---
import type { Lang } from '@i18n/ui';
import { useTranslations } from '@i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const subject = encodeURIComponent(lang === 'es' ? 'Columna propuesta — Meridiano' : 'Column proposal — Meridiano');
const mailto = `mailto:editorial@meridiano.com?subject=${subject}`;
---
<section class="bg-ink text-paper py-20 relative overflow-hidden" id="colabora">
  <div class="absolute inset-0 pointer-events-none"
       style="background:
         radial-gradient(ellipse at top left, rgba(184,147,79,0.08) 0%, transparent 50%),
         radial-gradient(ellipse at bottom right, rgba(200,16,46,0.08) 0%, transparent 50%);"></div>

  <div class="max-w-[960px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-15 relative" style="gap: 60px;">
    <div>
      <div class="font-sans text-[11px] font-bold tracking-[0.18em] uppercase text-gold mb-4">
        {lang === 'es' ? 'Colabora con Meridiano' : 'Write for Meridiano'}
      </div>
      <h2 class="font-display font-light text-[clamp(34px,4vw,48px)] leading-[1.05] tracking-[-0.025em] mb-5"
          style="font-variation-settings: 'opsz' 144;">
        {lang === 'es'
          ? <>Tu voz en el <em class="italic text-gold font-normal">debate global</em></>
          : <>Your voice in the <em class="italic text-gold font-normal">global debate</em></>}
      </h2>
      <p class="text-[15px] leading-[1.6] opacity-80 mb-8">
        {lang === 'es'
          ? 'Publicamos columnas de opinión de expertos, académicos y profesionales. Envianos tu propuesta por correo y te respondemos en 48–72 horas.'
          : 'We publish opinion columns from experts, academics and professionals. Send us your proposal by email and we\'ll get back to you within 48–72 hours.'}
      </p>
      <div class="font-sans text-[12px] opacity-65 leading-[2] mb-8">
        <span class="text-gold font-semibold tracking-[0.05em]">01 —</span>
        {lang === 'es' ? ' Escribe tu columna (600–1500 palabras)' : ' Write your column (600–1500 words)'}<br />
        <span class="text-gold font-semibold tracking-[0.05em]">02 —</span>
        {lang === 'es' ? ' Envíala a editorial@meridiano.com' : ' Send it to editorial@meridiano.com'}<br />
        <span class="text-gold font-semibold tracking-[0.05em]">03 —</span>
        {lang === 'es' ? ' Respuesta editorial en 48–72 h' : ' Editorial response within 48–72 h'}
      </div>
      <a href={mailto}
         class="inline-block bg-gold text-ink px-6 py-3.5 font-sans text-[12px] font-bold tracking-[0.18em] uppercase rounded-sm transition hover:bg-paper hover:-translate-y-0.5">
        {lang === 'es' ? 'Escribir al editor' : 'Contact the editor'}
      </a>
    </div>

    <div class="bg-paper/[0.04] border border-paper/15 rounded-sm p-8 flex flex-col justify-center gap-6">
      {[
        {
          n: '600–1500',
          label: lang === 'es' ? 'palabras por columna' : 'words per column',
        },
        {
          n: '48–72h',
          label: lang === 'es' ? 'tiempo de respuesta' : 'response time',
        },
        {
          n: lang === 'es' ? 'ES / EN' : 'EN / ES',
          label: lang === 'es' ? 'idiomas aceptados' : 'accepted languages',
        },
      ].map(({ n, label }) => (
        <div class="border-b border-paper/10 pb-6 last:border-0 last:pb-0">
          <div class="font-display text-[clamp(36px,4vw,52px)] font-light text-gold leading-none mb-1"
               style="font-variation-settings: 'opsz' 144;">{n}</div>
          <div class="font-sans text-[11px] tracking-[0.12em] uppercase opacity-60">{label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

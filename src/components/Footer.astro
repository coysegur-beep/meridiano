---
import type { Lang } from '@i18n/ui';
import { useTranslations, localePath } from '@i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<div class="bg-paper-light py-12 px-6 text-center border-y border-rule">
  <div class="font-sans text-[11px] font-bold tracking-[0.2em] uppercase text-red mb-2.5">{t('newsletter.eyebrow')}</div>
  <h3 class="font-display text-[32px] font-medium mb-1.5 tracking-[-0.02em]" style="font-variation-settings: 'opsz' 144;">
    {t('newsletter.title')}
  </h3>
  <p class="text-[14px] text-ink/80 mb-5">{t('newsletter.body')}</p>
  <form class="inline-flex gap-0 max-w-[500px] w-full" onsubmit="event.preventDefault(); alert(document.documentElement.lang === 'en' ? 'Subscribed!' : '¡Suscripción confirmada!');">
    <input type="email" placeholder="tu@email.com" required
           class="flex-1 px-4 py-3 border border-ink bg-paper font-serif text-[14px] rounded-l-sm focus:outline-none focus:border-red" />
    <button type="submit"
            class="px-5 py-3 border border-ink border-l-0 bg-ink text-paper font-sans text-[11px] font-bold tracking-[0.15em] uppercase cursor-pointer rounded-r-sm hover:bg-red hover:border-red transition">
      {t('cta.subscribe')}
    </button>
  </form>
</div>

<footer class="bg-ink text-paper py-15 px-6" style="padding-top: 60px; padding-bottom: 30px;">
  <div class="max-w-container mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.3fr_1fr_1fr_1fr] gap-10 pb-10 border-b border-paper/15">
    <div>
      <h4 class="font-display text-[32px] font-black tracking-[-0.03em] mb-2.5">MERIDIANO</h4>
      <p class="text-[13px] opacity-65 leading-[1.6] max-w-[320px]">{t('footer.brandBody')}</p>
      <div class="flex gap-3.5 mt-4 font-sans text-[10px] tracking-[0.1em] uppercase opacity-60">
        <span class="px-2 py-1 border border-paper/30 rounded-sm">ISO 27001</span>
        <span class="px-2 py-1 border border-paper/30 rounded-sm">IFCN</span>
        <span class="px-2 py-1 border border-paper/30 rounded-sm">SSL A+</span>
      </div>
    </div>
    <div>
      <h5 class="font-sans text-[11px] font-bold tracking-[0.15em] uppercase text-gold mb-3.5">{t('footer.sections')}</h5>
      <ul class="list-none space-y-2">
        <li><a href={localePath(lang, '/mundo')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('nav.world')}</a></li>
        <li><a href={localePath(lang, '/economia')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('nav.economy')}</a></li>
        <li><a href={localePath(lang, '/politica')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('nav.politics')}</a></li>
        <li><a href={localePath(lang, '/opinion')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('nav.opinion')}</a></li>
        <li><a href={localePath(lang, '/cultura')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('nav.culture')}</a></li>
      </ul>
    </div>
    <div>
      <h5 class="font-sans text-[11px] font-bold tracking-[0.15em] uppercase text-gold mb-3.5">{t('footer.company')}</h5>
      <ul class="list-none space-y-2">
        <li><a href={localePath(lang, '/sobre')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('footer.about')}</a></li>
        <li><a href={localePath(lang, '/estandares')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('footer.standards')}</a></li>
        <li><a href={localePath(lang, '/equipo')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('footer.team')}</a></li>
        <li><a href={localePath(lang, '/contacto')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('footer.contact')}</a></li>
        <li><a href={`${localePath(lang, '/')}#colabora`} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('cta.submit')}</a></li>
      </ul>
    </div>
    <div>
      <h5 class="font-sans text-[11px] font-bold tracking-[0.15em] uppercase text-gold mb-3.5">{t('footer.legal')}</h5>
      <ul class="list-none space-y-2">
        <li><a href={localePath(lang, '/privacidad')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('footer.privacy')}</a></li>
        <li><a href={localePath(lang, '/terminos')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('footer.terms')}</a></li>
        <li><a href={localePath(lang, '/cookies')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('footer.cookies')}</a></li>
        <li><a href={localePath(lang, '/correcciones')} class="text-paper font-sans text-[13px] opacity-75 hover:opacity-100 hover:text-gold transition">{t('footer.corrections')}</a></li>
      </ul>
    </div>
  </div>
  <div class="max-w-container mx-auto pt-6 flex flex-wrap justify-between gap-3 font-sans text-[11px] opacity-50">
    <div>© 2026 Meridiano Media S.A.S. · {t('footer.rights')}</div>
    <div>{t('footer.wireNote')}</div>
  </div>
</footer>

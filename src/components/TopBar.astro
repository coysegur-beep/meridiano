---
import type { Lang } from '@i18n/ui';
import { useTranslations, formatDate, otherLang, localePath } from '@i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const now = new Date();
const other = otherLang(lang);
const otherHref = localePath(other, Astro.url.pathname.replace(/^\/en/, '') || '/');
---
<div class="relative z-10 bg-ink text-paper">
  <div class="max-w-container mx-auto px-6 py-2.5 flex flex-wrap items-center justify-between gap-4 font-sans text-[11px] tracking-[0.08em] uppercase">
    <div class="flex items-center gap-5">
      <span class="opacity-75">{formatDate(now, lang)}</span>
      <span class="opacity-75 hidden sm:inline">☀ Bogotá 18°C · Madrid 14°C · NYC 9°C</span>
    </div>
    <div class="flex items-center gap-4">
      <div class="inline-flex border border-paper/25 rounded-sm overflow-hidden">
        <a href={localePath('es', Astro.url.pathname.replace(/^\/en/, '') || '/')}
           class={`px-2.5 py-1 transition ${lang === 'es' ? 'bg-paper text-ink' : ''}`}>ES</a>
        <a href={localePath('en', Astro.url.pathname.replace(/^\/en/, '') || '/')}
           class={`px-2.5 py-1 transition ${lang === 'en' ? 'bg-paper text-ink' : ''}`}>EN</a>
      </div>
      <a href={localePath(lang, '/enviar-columna')}
         class="text-gold border border-gold px-3 py-1 rounded-sm hover:bg-gold hover:text-ink transition font-semibold">
        {t('cta.submit')}
      </a>
    </div>
  </div>
</div>

# Dominio en producción (usado para canonical, OG, sitemap, hreflang)
SITE_URL=https://meridiano.example

# ---- Variables PUBLIC_ se inyectan en el cliente (Astro las expone con import.meta.env) ----

# Finnhub — para el ticker en vivo. Plan gratuito: finnhub.io/register
# Sin esta clave, el ticker muestra datos semilla con jitter simulado.
PUBLIC_FINNHUB_KEY=

# Endpoint del formulario de columnas (API Gateway que dispara la Lambda)
# Se define tras hacer `sam deploy` en lambda/submit-column/
PUBLIC_SUBMIT_ENDPOINT=

# ---- Solo backend (nunca se exponen al cliente) ----

# Agencia de noticias (AFP, AP, etc.) — solo al contratar
AGENCY_API_KEY=
